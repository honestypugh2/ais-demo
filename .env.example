# ============================================================================
# AIS Demo — environment configuration
# Copy to `.env` and fill in values. All values below are placeholders.
# The app runs fully in SIMULATED_MODE=true with NO Azure credentials.
# ============================================================================

# ── Run mode ────────────────────────────────────────────────────────────────
# true  -> use in-memory simulated backends (no Azure needed; great for demos)
# false -> use real Azure services via the SDKs below
SIMULATED_MODE=true
APP_ENV=development
LOG_LEVEL=INFO

# Use case profile (drives synthetic sample + labels). Generic by default.
USE_CASE_PROFILE=permit-intake

# ── Microsoft Entra (client-credentials for the front-end/consumer client) ──
TENANT_ID=<tenant-guid>
CLIENT_ID=<app-client-id>
CLIENT_SECRET=<app-client-secret>
API_SCOPE=api://ais-demo-permits/.default

# ── API Management (the governed front door) ────────────────────────────────
APIM_BASE=https://<your-apim>.azure-api.net
APIM_SUBSCRIPTION_KEY=<apim-subscription-key>
PERMITS_API_PATH=/permits/v1/permits

# ── Service Bus (durable messaging) ─────────────────────────────────────────
SERVICEBUS_FQDN=<your-namespace>.servicebus.windows.net
SERVICEBUS_QUEUE=permits-in

# ── Azure Document Intelligence (field extraction) ──────────────────────────
DOCINTEL_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
DOCINTEL_MODEL=prebuilt-layout

# ── Azure OpenAI via APIM AI gateway (compliance scoring model) ─────────────
AOAI_VIA_APIM_BASE=https://<your-apim>.azure-api.net/openai
AOAI_DEPLOYMENT=gpt-4o-mini
AOAI_API_VERSION=2024-10-21

# ── Event Grid (event-driven fan-out) ───────────────────────────────────────
EVENTGRID_ENDPOINT=https://<your-topic>.<region>-1.eventgrid.azure.net/api/events
EVENT_SOURCE=ais-demo/permitting
EVENT_TYPE_PREFIX=AisDemo.Permitting

# ── CRM target (Dynamics or an HTTP stub) ───────────────────────────────────
CRM_BASE=https://<your-crm-stub>.azurewebsites.net

# ── Observability (Application Insights / Log Analytics) ────────────────────
LOG_ANALYTICS_WORKSPACE_ID=<workspace-guid>
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── API host ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
COMPLIANCE_THRESHOLD=70
