<!--
  Permits API (orchestrated) — routes through a Logic App (Option A / Demo Track A7).

  POST /permits-orchestrated stamps a correlation ID and forwards the permit to
  the Logic App HTTP trigger, which orchestrates the enqueue to Service Bus and
  returns 202. This is the "APIM -> Logic App -> Service Bus" path that surfaces
  the Logic App "Runs history" orchestration view (A7). The Logic App callback
  URL (with its SAS signature) is held in the secret named value
  {{logicapp-callback-url}}.

  Demo Track: A6 (governed submit) + A7 (orchestration run history).
-->
<policies>
  <inbound>
    <base />
    <rate-limit-by-key calls="60" renewal-period="60"
                       counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />

    <set-variable name="correlationId"
                  value="@(context.Request.Headers.GetValueOrDefault("X-Correlation-Id", Guid.NewGuid().ToString()))" />
    <set-variable name="permitBody" value="@(context.Request.Body.As<string>(preserveContent: true))" />

    <!-- Forward to the Logic App HTTP trigger (orchestrates the enqueue). -->
    <send-request mode="new" response-variable-name="laresponse" timeout="30" ignore-error="false">
      <set-url>{{logicapp-callback-url}}</set-url>
      <set-method>POST</set-method>
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-header name="X-Correlation-Id" exists-action="override">
        <value>@((string)context.Variables["correlationId"])</value>
      </set-header>
      <set-body>@((string)context.Variables["permitBody"])</set-body>
    </send-request>

    <return-response>
      <set-status code="202" reason="Accepted" />
      <set-header name="X-Correlation-Id" exists-action="override">
        <value>@((string)context.Variables["correlationId"])</value>
      </set-header>
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-body>@("{\"status\":\"accepted\",\"via\":\"apim->logic-app\",\"correlationId\":\"" + (string)context.Variables["correlationId"] + "\"}")</set-body>
    </return-response>
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
