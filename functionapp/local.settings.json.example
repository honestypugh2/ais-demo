{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "ServiceBusConnection__fullyQualifiedNamespace": "<your-namespace>.servicebus.windows.net",
    "SIMULATED_MODE": "false",
    "USE_CASE_PROFILE": "permit-intake",
    "DOCINTEL_ENDPOINT": "https://<your-docintel>.cognitiveservices.azure.com/",
    "AOAI_VIA_APIM_BASE": "https://<your-apim>.azure-api.net/openai",
    "AOAI_DEPLOYMENT": "gpt-4o-mini",
    "AOAI_API_VERSION": "2024-10-21",
    "APIM_SUBSCRIPTION_KEY": "<apim-subscription-key>",
    "EVENTGRID_ENDPOINT": "https://<your-topic>.<region>-1.eventgrid.azure.net/api/events",
    "CRM_BASE": "https://<your-crm-stub>.azurewebsites.net",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": ""
  }
}
